import math

class shape:
    def area(self):
        pass 

class circle(shape):

    def __init__(self, radius):
        self.radius = radius 
    def area(self):
        return math.pi * (self.radius**2)
    
class rectangle(shape):

    def __init__(self, side):
        self.side = side 
    def area(self):   
        return (self.side**2) 
    
class triangle(shape):
    def __init__(self, base, height):
        self.base = base
        self.height = height 

    def area(self):
        return 0.5 * self.base * self.height 
    
shapes = [triangle(4, 3), rectangle(5), circle(8)]

for s in shapes:

    print(f"{type(s).__name__}, area = {s.area()}")
    
